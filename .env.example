# Server
PORT=5000
# NODE_ENV=production

# === Choose ONE AI provider ===

# Option A: Groq Cloud (free, for deployment)
# Get free API key at: https://console.groq.com
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# Option B: Ollama Local (default when GROQ_API_KEY is not set)
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434
# AI_TIMEOUT_MS=30000

# === Authentication (optional — disabled by default) ===
# AUTH_ENABLED=true
# AUTH_ADMIN_USER=admin
# AUTH_ADMIN_PASS=your_secure_password
# AUTH_SESSION_SECRET=random_64_char_hex_string
# AUTH_API_KEYS=sk-key1:admin,sk-key2:analyst
# AUTH_USERS=analyst1:pass1:analyst,viewer1:pass1:viewer

# === Alerting (optional) ===
# ALERT_MIN_SEVERITY=High

# Slack/Discord/Teams webhook
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Email alerts (requires: npm install nodemailer)
# ALERT_EMAIL_ENABLED=true
# ALERT_EMAIL_HOST=smtp.gmail.com
# ALERT_EMAIL_PORT=587
# ALERT_EMAIL_USER=your@email.com
# ALERT_EMAIL_PASS=your_app_password
# ALERT_EMAIL_TO=security-team@company.com

# SIEM export (CEF + JSON format)
# ALERT_SIEM_ENABLED=true

# === Logging ===
# LOG_LEVEL=INFO

# === Frontend URL (for CORS in production) ===
# FRONTEND_URL=https://your-app.vercel.app
